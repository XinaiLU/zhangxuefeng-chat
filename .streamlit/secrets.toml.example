# 本地：复制为 .streamlit/secrets.toml（已在 .gitignore，不会提交）
# 线上：Streamlit Cloud → App settings → Secrets

[qwen]
api_key = "sk-ws-你的百炼APIKey"
workspace_id = "ws-你的WorkspaceID"
model = "qwen-plus"

[app]
enable_search = true

# 可选：改用 OpenAI 兼容接口时注释掉 [qwen]，启用下方配置
# [openai]
# api_key = "sk-..."
# base_url = "https://api.openai.com/v1"
# model = "gpt-4o-mini"
